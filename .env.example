# Environment variables for the IoT API server

# Port to listen on (Render sets this automatically)
PORT=3000

# Your Supabase project URL (found in Project Settings > API)
SUPABASE_URL=your_supabase_project_url

# Supabase service role key (found in Project Settings > API — keep this secret!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Secret API key that all devices must send in the x-api-key header
API_KEY=your_secret_key_for_devices
